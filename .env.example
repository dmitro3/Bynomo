# =============================================================================
# BNB SMART CHAIN (BSC) CONFIGURATION
# =============================================================================

# BNB Smart Chain Configuration
# Network: 'mainnet' or 'testnet'
NEXT_PUBLIC_BNB_NETWORK=mainnet

# BNB RPC Endpoint
NEXT_PUBLIC_BNB_RPC_ENDPOINT=https://bsc-dataseed.binance.org/

# WalletConnect Project ID (Required for Wagmi/ConnectKit)
# Get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# =============================================================================
# PRIVY CONFIGURATION
# =============================================================================

# Privy App ID (from https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id

# Privy App Secret (Backend only - secure this!)
PRIVY_APP_SECRET=your-privy-app-secret

# =============================================================================
# TREASURY CONFIGURATION
# =============================================================================

# BNB Treasury
# Public address where BNB deposits are sent
NEXT_PUBLIC_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# BNB Treasury private key (Backend only - secure this!)
BNB_TREASURY_SECRET_KEY=your-bnb-treasury-secret-key

# Sui Treasury secret key (Backend only - secure this!)
# Format: suiprivkey1q...
SUI_TREASURY_SECRET_KEY=your-sui-treasury-secret-key

# Solana Configuration
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
# Solana RPC Endpoint (used by the backend and by wallet adapters)
NEXT_PUBLIC_SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOL_TREASURY_ADDRESS=your-solana-treasury-address
# Solana Treasury secret key (Backend only - secure this!)
SOL_TREASURY_SECRET_KEY=your-solana-treasury-secret-key

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

NEXT_PUBLIC_APP_NAME=Bynomo
NEXT_PUBLIC_ROUND_DURATION=30
NEXT_PUBLIC_PRICE_UPDATE_INTERVAL=1000
NEXT_PUBLIC_CHART_TIME_WINDOW=300000

# =============================================================================
# SUI NETWORK CONFIGURATION
# =============================================================================

NEXT_PUBLIC_SUI_NETWORK=mainnet
NEXT_PUBLIC_SUI_RPC_ENDPOINT=https://fullnode.mainnet.sui.io:443
NEXT_PUBLIC_SUI_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# USDC Token Type on Sui Mainnet
NEXT_PUBLIC_USDC_TYPE=0xdba34672e30cb065b1f93e3ab55318768fd6fef66c15942c9f7cb846e2f900e7::usdc::USDC

# =============================================================================
# STELLAR CONFIGURATION
# =============================================================================

NEXT_PUBLIC_STELLAR_NETWORK=public
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon.stellar.org
NEXT_PUBLIC_STELLAR_TREASURY_ADDRESS=your-stellar-treasury-address
# Stellar Treasury secret (Backend only - secure this! Format: S...)
STELLAR_TREASURY_SECRET=your-stellar-treasury-secret

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# =============================================================================
# TEZOS CONFIGURATION
# =============================================================================

NEXT_PUBLIC_TEZOS_RPC_URL=https://mainnet.ecadinfra.com
NEXT_PUBLIC_TEZOS_TREASURY_ADDRESS=tz1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Tezos Treasury secret key (Backend only - secure this! Format: edsk...)
TEZOS_TREASURY_SECRET_KEY=your-tezos-treasury-secret-key

# =============================================================================
# NEAR CONFIGURATION
# =============================================================================

NEXT_PUBLIC_NEAR_TREASURY_ADDRESS=your-near-treasury-account-id
NEAR_TREASURY_ACCOUNT_ID=your-near-treasury-account-id
# NEAR Treasury private key (Backend only - secure this! Format: ed25519:...)
NEAR_TREASURY_PRIVATE_KEY=your-near-treasury-private-key

# =============================================================================
# PUSH CHAIN CONFIGURATION
# =============================================================================

# Push Chain RPC Endpoint (EVM-compatible, Chain ID: 3400)
NEXT_PUBLIC_PUSH_RPC_ENDPOINT=https://evm.rpc.push.org

# Push Chain Treasury Address
# Can reuse your existing EVM treasury address (same wallet works on all EVM chains)
NEXT_PUBLIC_PUSH_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# Push Chain Treasury private key (Backend only - secure this!)
# Can reuse BNB_TREASURY_SECRET_KEY if using the same EVM wallet
PUSH_TREASURY_SECRET_KEY=your-push-treasury-secret-key

# =============================================================================
# STARKNET CONFIGURATION
# =============================================================================

# Starknet RPC Endpoint
NEXT_PUBLIC_STARKNET_RPC_URL=https://rpc.starknet.lava.build

# Starknet chain id (e.g. SN_MAIN)
NEXT_PUBLIC_STARKNET_CHAIN_ID=SN_MAIN

# Starknet Treasury address (used by backend withdrawals)
NEXT_PUBLIC_STARKNET_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# STRK token contract address (used as transfer target)
NEXT_PUBLIC_STARKNET_STRK_TOKEN_ADDRESS=0x04718f5a0fc34cc1af16a1cdee98ffb20c31f5d4f8b9e98e31f5f17d9d6c17d

# Starknet Treasury private key (Backend only - secure this!)
STARKNET_TREASURY_PRIVATE_KEY=your-starknet-treasury-private-key

# Cairo version: '0' | '1' (defaults to '1' if omitted)
STARKNET_TREASURY_CAIRO_VERSION=1

# =============================================================================
# POSTHOG ANALYTICS CONFIGURATION
# =============================================================================

# PostHog Project API Key (get from https://app.posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key

# PostHog API Host
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

