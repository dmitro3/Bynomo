# =============================================================================
# SOLANA BLOCKCHAIN CONFIGURATION
# =============================================================================

# Solana Network
# Options: devnet, testnet, mainnet-beta
NEXT_PUBLIC_SOLANA_NETWORK=testnet

# Solana RPC Endpoint
# The RPC endpoint URL for connecting to the Solana blockchain
# Testnet: https://api.testnet.solana.com
# Devnet: https://api.devnet.solana.com
# Mainnet: https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_RPC_ENDPOINT=https://api.testnet.solana.com

# =============================================================================
# TREASURY CONFIGURATION
# =============================================================================

# Treasury Wallet Address
# For Solana, we use a treasury wallet to receive deposits and send withdrawals
NEXT_PUBLIC_TREASURY_ADDRESS=your-solana-treasury-public-key

# Treasury Private Key (BACKEND ONLY)
# Used for processing withdrawals. Store this securely!
# Format: JSON array of numbers or Base58 string
SOLANA_TREASURY_SECRET_KEY=your-solana-treasury-secret-key

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================

# Supabase Project URL
# Get this from your Supabase project dashboard:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the "Project URL" (e.g., https://abcdefghijklmnop.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# Supabase Anonymous Key
# Get this from your Supabase project dashboard:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the "anon public" key from "Project API keys"
# This key is safe to use in client-side code
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application Name
# The name of your application (displayed in UI)
NEXT_PUBLIC_APP_NAME=Overflow

# Round Duration
# Duration of each betting round in seconds
# Default: 30 seconds
NEXT_PUBLIC_ROUND_DURATION=30

# Price Update Interval
# How often to fetch BTC price updates in milliseconds
# Default: 1000ms (1 second)
NEXT_PUBLIC_PRICE_UPDATE_INTERVAL=1000

# Chart Time Window
# Time window for the price chart in milliseconds
# Default: 300000ms (5 minutes)
NEXT_PUBLIC_CHART_TIME_WINDOW=300000
